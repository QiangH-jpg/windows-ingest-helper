{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "\u5143\u6cc9\u667a\u5f71\u4e0a\u4f20\u52a9\u624b",
  "version": "3.2.1",
  "identifier": "com.openclaw.uploader",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "\u5143\u6cc9\u667a\u5f71\u4e0a\u4f20\u52a9\u624b",
        "width": 680,
        "height": 720,
        "resizable": true,
        "center": true,
        "minWidth": 480,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' asset: tauri:; connect-src 'self' asset: tauri: http://47.93.194.154 http://localhost:*; img-src 'self' data: asset:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'unsafe-eval' asset: tauri:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "bin/ffmpeg",
      "bin/ffprobe"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
